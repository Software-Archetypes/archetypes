@startuml
skinparam linetype ortho
title Party Capability - Concrete Examples

' ===== EXAMPLE 1: ULTRASOUND TECHNICIAN =====
package "Example 1: Ultrasound Technician" #FFE0E0 {
  object maryTech {
    Party: Person
    name: "Maria Nowak"
  }

  object usgCapability {
    Capability
    --
    type: Medical Imaging
    validity: 2024-2026
  }

  object usgProtocolScope {
    ProtocolScope
    --
    protocol: "Ultrasound Imaging"
    procedures: ["Abdominal", "Cardiac", "Prenatal", "Thyroid"]
  }

  object usgLocationScope {
    LocationScope
    --
    location: "Medicode Warszawa Mokotów"
  }

  object usgTemporalScope {
    TemporalScope
    --
    hours: 8:00 - 16:00
    days: Mon-Fri
  }

  object usgQuantityScope {
    QuantityScope
    --
    quantity: 15 patients
    period: per day
  }

  maryTech -- usgCapability
  usgCapability *-- usgProtocolScope
  usgCapability *-- usgLocationScope
  usgCapability *-- usgTemporalScope
  usgCapability *-- usgQuantityScope
}

' ===== EXAMPLE 2: ELECTRICIAN =====
package "Example 2: Electrician" #E0FFE0 {
  object janElectric {
    Party: Person
    name: "Jan Kowalski"
  }

  object electricCapability {
    Capability
    --
    type: Electrical Installation
    validity: forever
  }

  object electricSkillScope {
    SkillLevelScope
    --
    skill: "Electrical Installation"
    level: 9/10
    certifications: ["SEP G1", "SEP D"]
  }

  object electricProtocolScope {
    ProtocolScope
    --
    protocol: "Building Installations"
    procedures: ["Residential", "Commercial", "Industrial"]
  }

  object electricLocationScope {
    LocationScope
    --
    location: "Kraków"
    radius: 30 km
  }

  object electricTemporalScope {
    TemporalScope
    --
    hours: 7:00 - 19:00
    days: Mon-Sat
  }

  janElectric -- electricCapability
  electricCapability *-- electricSkillScope
  electricCapability *-- electricProtocolScope
  electricCapability *-- electricLocationScope
  electricCapability *-- electricTemporalScope
}

' ===== EXAMPLE 3: DELIVERY DRIVER =====
package "Example 3: Delivery Driver" #E0E0FF {
  object piotrDriver {
    Party: Person
    name: "Piotr Wiśniewski"
  }

  object deliveryCapability {
    Capability
    --
    type: Goods Delivery
    validity: 2024-2025
  }

  object deliveryLocationScope {
    LocationScope
    --
    location: "Warszawa i okolice"
    radius: 50 km
  }

  object deliveryProductScope {
    ProductScope
    --
    categories: ["Electronics", "Furniture", "Food"]
    maxWeight: 500 kg
  }

  object deliveryQuantityScope {
    QuantityScope
    --
    quantity: 25 deliveries
    period: per day
  }

  object deliveryResourceScope {
    ResourceScope
    --
    resourceTypes: ["Van 3.5t"]
    maxCapacity: 15 m³
  }

  object deliveryTemporalScope {
    TemporalScope
    --
    hours: 6:00 - 22:00
    days: Mon-Sun
  }

  piotrDriver -- deliveryCapability
  deliveryCapability *-- deliveryLocationScope
  deliveryCapability *-- deliveryProductScope
  deliveryCapability *-- deliveryQuantityScope
  deliveryCapability *-- deliveryResourceScope
  deliveryCapability *-- deliveryTemporalScope
}

