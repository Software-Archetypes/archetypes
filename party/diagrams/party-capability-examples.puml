' ===== EXAMPLE 5: SOFTWARE HOUSE (ORGANIZATION) =====
package "Example 5: Software House (Organization)" #FFE0FF {
  object devProsoftware {
    Party: Organization
    name: "DevPro Software Sp. z o.o."
  }

  object softwareDevCapability {
    Capability
    --
    type: Software Development
    validity: forever
  }

  object techStackScope1 {
    SkillLevelScope
    --
    skill: "Java/Spring Boot"
    level: 9/10
    certifications: ["Oracle Partner", "Spring Certified"]
  }

  object techStackScope2 {
    SkillLevelScope
    --
    skill: "React/TypeScript"
    level: 8/10
    certifications: []
  }

  object projectScope {
    ProductScope
    --
    categories: ["Web Applications", "Mobile Apps", "API Development", "Cloud Migration"]
  }

  object locationScope {
    LocationScope
    --
    location: "Poland (Warszawa, Kraków, Wrocław)"
    radius: unlimited (remote teams)
  }

  object capacityScope {
    QuantityScope
    --
    quantity: 15 concurrent projects
    period: at any time
  }

  object resourceScope {
    ResourceScope
    --
    resourceTypes: ["Senior Developers: 25", "Mid Developers: 40", "QA Engineers: 10"]
    maxCapacity: 75 people
  }

  devProsoftware -- softwareDevCapability
  softwareDevCapability *-- techStackScope1
  softwareDevCapability *-- techStackScope2
  softwareDevCapability *-- projectScope
  softwareDevCapability *-- locationScope
  softwareDevCapability *-- capacityScope
  softwareDevCapability *-- resourceScope
}

' ===== EXAMPLE 6: DEVELOPMENT TEAM (ORGANIZATION UNIT) =====
package "Example 6: Development Team (Org Unit)" #E0F0FF {
  object backendTeam {
    Party: OrganizationUnit
    name: "Backend Team Alpha"
  }

  object teamCapability {
    Capability
    --
    type: Backend Development
    validity: 2024-2025
  }

  object teamSkillScope {
    SkillLevelScope
    --
    skill: "Microservices Architecture"
    level: 9/10
    certifications: ["AWS Certified", "Kubernetes Certified"]
  }

  object teamProtocolScope {
    ProtocolScope
    --
    protocol: "Agile/Scrum Development"
    procedures: ["Sprint Planning", "Code Review", "CI/CD", "Pair Programming"]
  }

  object teamProductScope {
    ProductScope
    --
    categories: ["REST APIs", "Event-Driven Systems", "Database Design"]
  }


  object teamResourceScope {
    ResourceScope
    --
    resourceTypes: ["Backend Developers: 6", "Tech Lead: 1", "DevOps: 1"]
    maxCapacity: 8 people
  }

  object teamTemporalScope {
    TemporalScope
    --
    hours: 9:00 - 17:00
    days: Mon-Fri
  }

  backendTeam -- teamCapability
  teamCapability *-- teamSkillScope
  teamCapability *-- teamProtocolScope
  teamCapability *-- teamProductScope
  teamCapability *-- teamResourceScope
  teamCapability *-- teamTemporalScope
}

'note bottom of maryTech
'  **Capability Query Examples:**
'
'  **Person Examples:**
'  Can Maria do prenatal USG on Wednesday at 10:00?
'  → YES (has ProtocolScope "Prenatal" + TemporalScope Wed 8-16)
'
'  Can Maria do USG on Saturday?
'  → NO (TemporalScope: Mon-Fri only)
'
'  Can Jan install industrial electrical system in Wieliczka (15 km)?
'  → YES (has ProtocolScope "Industrial" + LocationScope 30 km radius)
'
'  Can Piotr deliver 30 packages in one day?
'  → NO (QuantityScope: max 25 deliveries/day)
'
'  Can Anna do anti-aging treatment on Monday?
'  → NO (TemporalScope: Tue-Sat only)
'
'  **Organization Examples:**
'  Can DevPro Software handle a new React project?
'  → YES (has SkillLevelScope "React/TypeScript" 8/10)
'
'  Can DevPro Software take on 20 projects at once?
'  → NO (QuantityScope: max 15 concurrent projects)
'
'  **Team Examples:**
'  Can Backend Team Alpha deliver 150 story points in 2 weeks?
'  → NO (QuantityScope: max 120 SP per sprint)
'
'  Can Backend Team Alpha design event-driven system?
'  → YES (has ProductScope "Event-Driven Systems")
'end note

@enduml
