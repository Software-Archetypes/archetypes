@startuml
skinparam rectangle {
  BackgroundColor<<Party>> #E6F3FF
  BorderColor<<Party>> #333333
}

skinparam card {
  BackgroundColor<<Capability>> #FFE6CC
  BorderColor<<Capability>> #CC9966
}

skinparam cloud {
  BackgroundColor<<Role>> #E8F5E9
  BorderColor<<Role>> #66CC66
}

skinparam component {
  BackgroundColor<<Relationship>> #F5E8E8
  BorderColor<<Relationship>> #CC6666
}

title TransPol Logistics Network - Party Graph with Roles and Capabilities

' ===== PARTIES =====
rectangle "TransPol Logistics\n(Organization)" as TransPol <<Party>>
rectangle "FastTrack\n(Organization)" as FastTrack <<Party>>
rectangle "Marek Kwiatkowski\n(Person)" as Marek <<Party>>
rectangle "Kasia Zawadzka\n(Person)" as Kasia <<Party>>
rectangle "EcoFleet\n(Organization)" as EcoFleet <<Party>>
rectangle "Krzysztof Płatek\n(Person)" as Krzysztof <<Party>>
rectangle "GreenCharge\n(Organization)" as GreenCharge <<Party>>
rectangle "Ola Wilk\n(Person)" as Ola <<Party>>
rectangle "CargoMate\n(Organization)" as CargoMate <<Party>>
rectangle "Adam Nowak\n(Person)" as Adam <<Party>>
rectangle "Piotr Lewandowski\n(Person)" as Piotr <<Party>>
rectangle "InsurSafe\n(Organization)" as InsurSafe <<Party>>
rectangle "Ewa Malec\n(Person)" as Ewa <<Party>>
rectangle "Robert Kania\n(Person)" as Robert <<Party>>

' ===== ROLES (independent) =====
cloud "3PL Provider" as Role_TransPol <<Role>>
cloud "Express Delivery\nPartner" as Role_FastTrack <<Role>>
cloud "Green Delivery\nPartner" as Role_EcoFleet <<Role>>
cloud "Courier" as Role_Marek <<Role>>
cloud "Food Courier" as Role_Kasia <<Role>>
cloud "EV Driver" as Role_Krzysztof <<Role>>
cloud "Charging Provider" as Role_GreenCharge <<Role>>
cloud "Technician" as Role_Ola <<Role>>
cloud "Freight Carrier" as Role_CargoMate <<Role>>
cloud "Heavy Driver" as Role_Adam <<Role>>
cloud "Furniture Driver" as Role_Piotr <<Role>>
cloud "Insurer" as Role_InsurSafe <<Role>>
cloud "Risk Assessor" as Role_Ewa <<Role>>
cloud "Claims Handler" as Role_Robert <<Role>>

' ===== CAPABILITIES =====
card "Freight Management\nRegions: PL, DE, CZ\n100 shipments/day" as TransPol_Cap1 <<Capability>>
card "Express Delivery\nWarsaw, 50km\n40 deliveries/day" as FastTrack_Cap1 <<Capability>>
card "Goods Delivery\nDocuments, max 50kg" as Marek_Cap1 <<Capability>>
card "Route Optimization\nSkill: 8/10, Certified" as Marek_Cap2 <<Capability>>
card "Food Delivery\nCold Chain\n25 deliveries/day" as Kasia_Cap1 <<Capability>>
card "Goods Delivery (EV)\nRange: 150km\nWarsaw, Łódź" as EcoFleet_Cap1 <<Capability>>
card "Charging Management\n12 stations\nPL-Central" as EcoFleet_Cap2 <<Capability>>
card "Goods Delivery\nEV Van, 800kg" as Krzysztof_Cap1 <<Capability>>
card "Electric Fleet Charging\nPL, CZ" as GreenCharge_Cap1 <<Capability>>
card "Infrastructure Maintenance\nSkill: 7/10\nCert: Safety+" as Ola_Cap1 <<Capability>>
card "Heavy Freight\nTrucks >12t\nEU-wide" as CargoMate_Cap1 <<Capability>>
card "Heavy Truck Driving\nLicense: C+E\nRange: 500km" as Adam_Cap1 <<Capability>>
card "Furniture Transport\nmax 900kg\nRadius: 70km" as Piotr_Cap1 <<Capability>>
card "Cargo Insurance\nGoods in Transit\nWarehousing" as InsurSafe_Cap1 <<Capability>>
card "Risk Assessment\nSkill: 9, Certified" as Ewa_Cap1 <<Capability>>
card "Customer Claims Handling\nEN/DE, 5y exp" as Robert_Cap1 <<Capability>>

