@startuml
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 80
title TransPol Logistics Network - Party Graph with Capabilities

' ===== MAIN ORGANIZATION =====
package "TransPol Logistics" #E6F3FF {
  object "TransPol Logistics\n<<Organization>>" as TransPol {
    partyId: TP-001
    --
    **Role**: Dostawca 3PL
  }

  object "Freight Management" as TP_Cap1 <<Capability>> {
    type: Freight Management
    regions: [PL, DE, CZ]
    quantity: 100 shipments/day
  }

  TransPol -- TP_Cap1
}

' ===== FASTTRACK PARTNER =====
package "FastTrack - Express Delivery" #FFF4E6 {
  object "FastTrack\n<<Organization>>" as FastTrack {
    partyId: FT-001
    --
    **Role**: Express Delivery Partner
  }

  object "Express Delivery" as FT_Cap1 <<Capability>> {
    type: Express Delivery
    region: Warsaw, 50km
    quantity: 40 deliveries/day
  }

  object "Marek Kwiatkowski\n<<Person>>" as Marek {
    partyId: MK-001
  }

  object "Goods Delivery" as MK_Cap1 <<Capability>> {
    type: Goods Delivery
    category: Documents
    maxWeight: 50kg
  }

  object "Route Optimization" as MK_Cap2 <<Capability>> {
    type: Route Optimization
    skillLevel: 8/10
    certified: Yes
  }

  object "Kasia Zawadzka\n<<Person>>" as Kasia {
    partyId: KZ-001
  }

  object "Food Delivery" as KZ_Cap1 <<Capability>> {
    type: Food Delivery
    coldChain: Yes
    quantity: 25 deliveries/day
  }

  FastTrack -- FT_Cap1
  Marek -- MK_Cap1
  Marek -- MK_Cap2
  Kasia -- KZ_Cap1
}

' ===== ECOFLEET PARTNER =====
package "EcoFleet - Green Delivery" #E8F5E9 {
  object "EcoFleet\n<<Organization>>" as EcoFleet {
    partyId: EF-001
    --
    **Role**: Green Delivery Partner
  }

  object "Goods Delivery (EV)" as EF_Cap1 <<Capability>> {
    type: Goods Delivery
    fleet: EV
    range: 150km
    locations: [Warsaw, Łódź]
  }

  object "Charging Management" as EF_Cap2 <<Capability>> {
    type: Charging Management
    stations: 12
    locations: PL-Central
  }

  object "Krzysztof Płatek\n<<Person>>" as Krzysztof {
    partyId: KP-001
  }

  object "Goods Delivery (EV Van)" as KP_Cap1 <<Capability>> {
    type: Goods Delivery
    vehicle: EV Van
    maxLoad: 800kg
  }

  object "GreenCharge\n<<Organization>>" as GreenCharge {
    partyId: GC-001
  }

  object "Electric Fleet Charging" as GC_Cap1 <<Capability>> {
    type: Electric Fleet Charging
    scope: [PL, CZ]
  }

  object "Ola Wilk\n<<Person>>" as Ola {
    partyId: OW-001
  }

  object "Infrastructure Maintenance" as OW_Cap1 <<Capability>> {
    type: Infrastructure Maintenance
    skillLevel: 7/10
    certification: Safety+
  }

  EcoFleet -- EF_Cap1
  EcoFleet -- EF_Cap2
  Krzysztof -- KP_Cap1
  GreenCharge -- GC_Cap1
  Ola -- OW_Cap1
}

' ===== CARGOMATE PARTNER =====
package "CargoMate - Heavy Freight" #FFF0F5 {
  object "CargoMate\n<<Organization>>" as CargoMate {
    partyId: CM-001
  }

  object "Heavy Freight" as CM_Cap1 <<Capability>> {
    type: Heavy Freight
    trucks: >12t
    scope: EU-wide
  }

  object "Adam Nowak\n<<Person>>" as Adam {
    partyId: AN-001
  }

  object "Heavy Truck Driving" as AN_Cap1 <<Capability>> {
    type: Heavy Truck Driving
    license: C+E
    range: 500km
  }

  object "Piotr Lewandowski\n<<Person>>" as Piotr {
    partyId: PL-001
  }

  object "Furniture Transport" as PL_Cap1 <<Capability>> {
    type: Furniture Transport
    maxWeight: 900kg
    radius: 70km
  }

  CargoMate -- CM_Cap1
  Adam -- AN_Cap1
  Piotr -- PL_Cap1
}

' ===== INSURSAFE PARTNER =====
package "InsurSafe - Insurance" #F0F8FF {
  object "InsurSafe\n<<Organization>>" as InsurSafe {
    partyId: IS-001
  }

  object "Cargo Insurance" as IS_Cap1 <<Capability>> {
    type: Cargo Insurance
    products: [Goods in Transit, Warehousing]
  }

  object "Ewa Malec\n<<Person>>" as Ewa {
    partyId: EM-001
  }

  object "Risk Assessment" as EM_Cap1 <<Capability>> {
    type: Risk Assessment
    skillLevel: 9
    certified: Yes
  }

  object "Robert Kania\n<<Person>>" as Robert {
    partyId: RK-001
  }

  object "Customer Claims Handling" as RK_Cap1 <<Capability>> {
    type: Customer Claims Handling
    languages: [EN, DE]
    experience: 5y
  }

  InsurSafe -- IS_Cap1
  Ewa -- EM_Cap1
  Robert -- RK_Cap1
}

